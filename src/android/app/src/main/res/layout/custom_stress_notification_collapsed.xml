<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:background="@drawable/card_notif_bg"
    android:paddingHorizontal="16dp"
    android:paddingVertical="6dp">

    <ImageView
        android:id="@+id/notif_icon_bg"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:background="@drawable/circle_icon_bg"
        android:src="@drawable/circle_trend_icon"
        android:padding="7dp" />

    <TextView
        android:id="@+id/notif_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/notif_icon_bg"
        android:layout_toStartOf="@id/notif_score"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="Stress Level"
        android:textColor="#1A1A1A"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/notif_status_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:background="@drawable/pill_status_bg"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp"
        android:text="Stable"
        android:textColor="#666666"
        android:textSize="11sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/notif_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toStartOf="@id/notif_status_pill"
        android:layout_centerVertical="true"
        android:layout_marginEnd="12dp"
        android:text="74/100"
        android:textColor="#0077FF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />
</RelativeLayout>
